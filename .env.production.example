# Copy these to Railway → Project → Variables

# Supabase connection (use the pooler URLs from Supabase Connect → ORM → Prisma)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres?schema=public"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your-production-secret-here"

# Set this to your Railway public URL after first deploy
NEXTAUTH_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_SHORT_URL="https://link-vaults.io"
NEXT_PUBLIC_APP_NAME="LinkVault"
