generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING   // waiting for admin approval
  ACTIVE    // approved and can login
  SUSPENDED // banned/suspended
}

enum LinkStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  EXPIRED
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  RESTORE
  LOGIN
  LOGOUT
  EXPORT
  BULK_DELETE
  BULK_UPDATE
  PASSWORD_CHANGE
  API_KEY_CREATE
  API_KEY_REVOKE
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  passwordHash   String?
  avatarUrl      String?
  role           UserRole      @default(USER)
  status         AccountStatus @default(PENDING)
  isBanned       Boolean       @default(false)
  banReason      String?
  emailVerified  Boolean       @default(false)
  timezone       String        @default("UTC")
  locale         String        @default("en")
  preferences    Json          @default("{}")
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  projects       Project[]
  links          DynamicLink[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  sessions       UserSession[]
  settings       UserSettings?

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  theme                 String  @default("system")
  emailNotifications    Boolean @default(true)
  weeklyReport          Boolean @default(true)
  linkCreatedAlert      Boolean @default(false)
  clickThresholdAlert   Boolean @default(false)
  clickThreshold        Int     @default(1000)
  defaultRedirectDelay  Int     @default(0)
  defaultLinkExpiry     Int?
  publicProfile         Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── PROJECTS ────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String   @default("#6366f1")
  icon        String?
  isDefault   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  links DynamicLink[]

  @@index([userId])
  @@index([deletedAt])
  @@map("projects")
}

// ─── DYNAMIC LINKS ───────────────────────────────────────────────────────────

model DynamicLink {
  id              String     @id @default(cuid())
  userId          String
  projectId       String?
  slug            String     @unique
  destinationUrl  String
  title           String?
  description     String?
  // Password protection (bcrypt hash)
  password        String?
  // Expiry
  expiresAt       DateTime?
  // Click limits
  maxClicks       Int?
  totalClicks     Int        @default(0)
  uniqueClicks    Int        @default(0)
  // Status
  status          LinkStatus @default(ACTIVE)
  // Redirect behaviour
  redirectDelay   Int        @default(0)
  // Open Graph
  ogImage         String?
  ogTitle         String?
  ogDescription   String?
  faviconUrl      String?
  // Metadata
  tags            String[]   @default([])
  notes           String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  // Custom domain
  customDomainId  String?
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customDomain CustomDomain? @relation(fields: [customDomainId], references: [id], onDelete: SetNull)
  history      LinkHistory[]
  analytics    Analytics[]
  visitors     Visitor[]

  @@index([slug])
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([tags])
  @@map("dynamic_links")
}

// ─── LINK HISTORY ────────────────────────────────────────────────────────────

model LinkHistory {
  id             String   @id @default(cuid())
  linkId         String
  userId         String
  oldUrl         String
  newUrl         String
  changeNote     String?
  createdAt      DateTime @default(now())

  link DynamicLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([userId])
  @@index([createdAt])
  @@map("link_history")
}

// ─── ANALYTICS ───────────────────────────────────────────────────────────────

model Analytics {
  id          String   @id @default(cuid())
  linkId      String
  // Geo
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  // Tech
  browser     String?
  browserVersion String?
  os          String?
  osVersion   String?
  device      DeviceType @default(UNKNOWN)
  screenWidth Int?
  screenHeight Int?
  // Network
  ip          String?
  referrer    String?
  refererDomain String?
  userAgent   String?
  // Language & locale
  language    String?
  timezone    String?
  // UTM
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  // Session
  visitorId   String?
  isUnique    Boolean  @default(true)
  isBot       Boolean  @default(false)
  // Click
  clickedAt   DateTime @default(now())

  link    DynamicLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  visitor Visitor?    @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([linkId])
  @@index([country])
  @@index([browser])
  @@index([os])
  @@index([device])
  @@index([clickedAt])
  @@index([visitorId])
  @@index([isBot])
  @@map("analytics")
}

// ─── VISITORS ────────────────────────────────────────────────────────────────

model Visitor {
  id          String   @id @default(cuid())
  linkId      String
  fingerprint String
  ip          String?
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  totalVisits Int      @default(1)

  link      DynamicLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  analytics Analytics[]

  @@unique([linkId, fingerprint])
  @@index([linkId])
  @@index([fingerprint])
  @@map("visitors")
}

// ─── CUSTOM DOMAINS ──────────────────────────────────────────────────────────

model CustomDomain {
  id          String   @id @default(cuid())
  userId      String
  domain      String   @unique
  verified    Boolean  @default(false)
  verifyToken String   @unique @default(cuid())
  sslEnabled  Boolean  @default(false)
  isDefault   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  links DynamicLink[]

  @@index([userId])
  @@index([domain])
  @@map("custom_domains")
}

// ─── API KEYS ─────────────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]  @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── USER SESSIONS ────────────────────────────────────────────────────────────

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique
  ipAddress  String?
  userAgent  String?
  country    String?
  city       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("user_sessions")
}
